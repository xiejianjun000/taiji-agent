# Dependencies (will be installed in container)
node_modules/

# Build artifacts (will be built in container)
dist/
bundle/
release/

# Electron / Desktop (not needed for server image, but keep package.json
# so pnpm can resolve the full workspace during install)
packages/desktop/
!packages/desktop/package.json

# CLI (not needed for server image, but keep package.json for workspace resolution)
packages/cli/
!packages/cli/package.json

# Development files
.git/
.github/
.env
.env.*
*.db
*.db-journal
coverage/
logs/
*.log
.turbo/
.DS_Store

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo

# Docker files themselves
Dockerfile
docker-compose*.yml
.dockerignore
