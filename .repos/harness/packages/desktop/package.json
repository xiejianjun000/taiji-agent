{
  "name": "@harness/desktop",
  "version": "0.1.0",
  "description": "Electron desktop client for the Harness LLM agent runtime",
  "main": "./dist/main/index.js",
  "type": "commonjs",
  "scripts": {
    "build": "tsc && tsc -p tsconfig.renderer.json && node -e \"const fs=require('fs');const p=require('path');const src='src/renderer';const dst='dist/renderer';for(const f of fs.readdirSync(src)){if(/\\.(html|css)$/.test(f)){fs.cpSync(p.join(src,f),p.join(dst,f))}}\"",
    "clean": "rm -rf dist bundle release",
    "start": "electron ./dist/main/index.js",
    "dev": "pnpm run build && electron ./dist/main/index.js",
    "bundle": "node scripts/bundle.mjs",
    "dist": "pnpm run bundle && electron-builder --config electron-builder.yml",
    "dist:mac": "pnpm run bundle && electron-builder --config electron-builder.yml --mac",
    "dist:win": "pnpm run bundle && electron-builder --config electron-builder.yml --win",
    "dist:linux": "pnpm run bundle && electron-builder --config electron-builder.yml --linux",
    "rebuild-native": "electron-rebuild -f -w better-sqlite3"
  },
  "dependencies": {
    "@harness/core": "workspace:*",
    "@harness/plugin-heartbeat": "workspace:*",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.0",
    "@types/node": "^22.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.24.0",
    "typescript": "^5.7.0"
  },
  "license": "MIT"
}
