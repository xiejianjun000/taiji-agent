{
  "name": "harness",
  "version": "0.1.0",
  "private": true,
  "description": "Universal LLM Agent Runtime",
  "license": "MIT",
  "bin": {
    "harness": "./packages/cli/dist/index.js"
  },
  "scripts": {
    "build": "pnpm -r build",
    "clean": "pnpm -r clean",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "desktop": "pnpm --filter @harness/desktop dev",
    "desktop:build": "pnpm --filter @harness/desktop build",
    "desktop:bundle": "pnpm --filter @harness/desktop bundle",
    "desktop:dist": "pnpm --filter @harness/desktop dist",
    "desktop:dist:mac": "pnpm --filter @harness/desktop dist:mac",
    "desktop:dist:win": "pnpm --filter @harness/desktop dist:win",
    "desktop:dist:linux": "pnpm --filter @harness/desktop dist:linux"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "electron",
      "esbuild"
    ]
  }
}