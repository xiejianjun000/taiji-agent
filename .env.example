# OpenTaiji 环境变量配置示例
# 复制此文件为 .env.production 并填入实际值

# ==================== 基础配置 ====================
NODE_ENV=production
PORT=3000
LOG_LEVEL=info
LOG_FORMAT=json

# ==================== 安全配置 ====================
# JWT 密钥（生产环境必须修改）
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# 加密密钥（生产环境必须修改）
ENCRYPTION_KEY=your-encryption-key-32-chars-long

# API 密钥
API_KEY=your-api-key-here

# ==================== 数据库配置 ====================
# Redis
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# PostgreSQL (如果使用)
DATABASE_URL=postgresql://user:password@localhost:5432/opentaiji

# ==================== LLM 配置 ====================
# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1

# Azure OpenAI
AZURE_OPENAI_API_KEY=your-azure-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com

# 百度文心一言
BAIDU_API_KEY=your-baidu-key
BAIDU_SECRET_KEY=your-baidu-secret

# 阿里通义千问
ALIBABA_API_KEY=your-alibaba-key

# 腾讯混元
TENCENT_SECRET_ID=your-tencent-id
TENCENT_SECRET_KEY=your-tencent-key

# ==================== 监控配置 ====================
# Prometheus
METRICS_ENABLED=true
PROMETHEUS_PORT=9090

# Jaeger 追踪
JAEGER_ENABLED=true
JAEGER_ENDPOINT=http://localhost:14268/api/traces

# ==================== WFGY 反幻觉配置 ====================
WFGY_ENABLED=true
WFGY_VERIFICATION_LEVEL=strict
WFGY_SYMBOLIC_LAYER_URL=http://localhost:8081

# ==================== Actor Runtime 配置 ====================
ACTOR_MAILBOX_SIZE=100
ACTOR_SUPERVISION_STRATEGY=restart
ACTOR_MAX_RESTARTS=10
ACTOR_RESTART_WINDOW=60

# ==================== 限流配置 ====================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=1000
RATE_LIMIT_BURST=100

# ==================== 缓存配置 ====================
CACHE_ENABLED=true
CACHE_TTL=3600
CACHE_MAX_SIZE=10000

# ==================== 邮件配置（告警用） ====================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
ALERT_EMAIL=alerts@yourcompany.com
